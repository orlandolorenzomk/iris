{
  "info": {
    "name": "Nexus API",
    "_postman_id": "nexus-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "userId", "value": "" },
    { "key": "spaceId", "value": "" },
    { "key": "networkId", "value": "" },
    { "key": "machineId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) {",
                  "    pm.globals.set('jwt_nexus', json.token);",
                  "    pm.collectionVariables.set('userId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"orlandolorenzo@kreyzon.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"Password1!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/users",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users"]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"updated@example.com\",\n  \"password\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}"]
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "users", "{{userId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Spaces",
      "item": [
        {
          "name": "Get Space by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/spaces/{{spaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["spaces", "{{spaceId}}"]
            }
          }
        },
        {
          "name": "Get Spaces by User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/spaces/user/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["spaces", "user", "{{userId}}"]
            }
          }
        },
        {
          "name": "Create Space",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.id) {",
                  "    pm.collectionVariables.set('spaceId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"name\": \"my-space\",\n  \"cpuLimit\": 4,\n  \"ramLimit\": 8192,\n  \"storageLimit\": 100\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/spaces",
              "host": ["{{baseUrl}}"],
              "path": ["spaces"]
            }
          }
        },
        {
          "name": "Update Space",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"my-space-updated\",\n  \"cpuLimit\": null,\n  \"ramLimit\": null,\n  \"storageLimit\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/spaces/{{spaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["spaces", "{{spaceId}}"]
            }
          }
        },
        {
          "name": "Delete Space",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/spaces/{{spaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["spaces", "{{spaceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Space Networks",
      "item": [
        {
          "name": "Get Network by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/space-networks/{{networkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["space-networks", "{{networkId}}"]
            }
          }
        },
        {
          "name": "Get Networks by Space",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/space-networks/space/{{spaceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["space-networks", "space", "{{spaceId}}"]
            }
          }
        },
        {
          "name": "Create Space Network",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.id) {",
                  "    pm.collectionVariables.set('networkId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": \"{{spaceId}}\",\n  \"vnetId\": \"space-42\",\n  \"subnet\": \"10.42.0.0/24\",\n  \"vni\": 10042\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/space-networks",
              "host": ["{{baseUrl}}"],
              "path": ["space-networks"]
            }
          }
        },
        {
          "name": "Update Network Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/space-networks/{{networkId}}/status?status=READY",
              "host": ["{{baseUrl}}"],
              "path": ["space-networks", "{{networkId}}", "status"],
              "query": [{ "key": "status", "value": "READY" }]
            }
          }
        },
        {
          "name": "Delete Space Network",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/space-networks/{{networkId}}",
              "host": ["{{baseUrl}}"],
              "path": ["space-networks", "{{networkId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Machines",
      "item": [
        {
          "name": "Get Machine by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/machines/{{machineId}}",
              "host": ["{{baseUrl}}"],
              "path": ["machines", "{{machineId}}"]
            }
          }
        },
        {
          "name": "Get All Machines",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/machines",
              "host": ["{{baseUrl}}"],
              "path": ["machines"]
            }
          }
        },
        {
          "name": "Create Machine",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json && json.id) {",
                  "    pm.collectionVariables.set('machineId', json.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"node-01\",\n  \"host\": \"192.168.1.10\",\n  \"sshPort\": 22,\n  \"sshUser\": \"root\",\n  \"sshKeyEnc\": \"<encrypted-key>\",\n  \"secretKeyId\": \"key-id\",\n  \"mgmtIface\": \"eth0\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/machines",
              "host": ["{{baseUrl}}"],
              "path": ["machines"]
            }
          }
        },
        {
          "name": "Update Machine",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"node-01-updated\",\n  \"host\": null,\n  \"sshPort\": null,\n  \"sshUser\": null,\n  \"sshKeyEnc\": null,\n  \"secretKeyId\": null,\n  \"mgmtIface\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/machines/{{machineId}}",
              "host": ["{{baseUrl}}"],
              "path": ["machines", "{{machineId}}"]
            }
          }
        },
        {
          "name": "Update Machine Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/machines/{{machineId}}/status?status=ACTIVE",
              "host": ["{{baseUrl}}"],
              "path": ["machines", "{{machineId}}", "status"],
              "query": [{ "key": "status", "value": "ACTIVE" }]
            }
          }
        },
        {
          "name": "Delete Machine",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/machines/{{machineId}}",
              "host": ["{{baseUrl}}"],
              "path": ["machines", "{{machineId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Cluster Settings",
      "item": [
        {
          "name": "Get Cluster Settings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/cluster-settings",
              "host": ["{{baseUrl}}"],
              "path": ["cluster-settings"]
            }
          }
        },
        {
          "name": "Update Cluster Settings",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_nexus}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sdnZoneType\": \"VXLAN\",\n  \"sdnZoneName\": \"iris\",\n  \"natsUrl\": \"nats://localhost:4222\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/cluster-settings",
              "host": ["{{baseUrl}}"],
              "path": ["cluster-settings"]
            }
          }
        }
      ]
    }
  ]
}
